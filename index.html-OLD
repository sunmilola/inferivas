<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Inferiva | Powering Transformations That Stick</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    :root{
      --ink:#101828;
      --muted:#5f6c7b;
      --line:#e7edf3;
      --panel:#ffffff;
      --bg:#f7fafc;
      --brand:#0f5fd7;
      --brand-dark:#0b4fb6;
      --brand-soft:#edf4ff;
      --navy:#0d1b2a;
    }
    html{scroll-behavior:smooth}
    body{
      margin:0;
      font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      background:linear-gradient(180deg,#fbfdff 0%,#f7fafc 100%);
      color:var(--ink);
    }
    .site-header{
      background:rgba(255,255,255,.84);
      backdrop-filter: blur(14px);
      border-bottom:1px solid rgba(231,237,243,.9);
      box-shadow:0 10px 28px rgba(16,24,40,.04);
    }
    .nav-link{
      position:relative;
      color:#344054;
      font-weight:600;
      transition:color .2s ease;
    }
    .nav-link:hover,.nav-link.active{color:var(--brand)}
    .nav-link::after{
      content:"";
      position:absolute;
      left:0;
      bottom:-10px;
      width:100%;
      height:2px;
      background:var(--brand);
      transform:scaleX(0);
      transform-origin:left;
      transition:transform .2s ease;
    }
    .nav-link:hover::after,.nav-link.active::after{transform:scaleX(1)}
    .hero-bg{
      position:relative;
      overflow:hidden;
      background:linear-gradient(180deg,#f8fbff 0%, #ffffff 100%);
    }
    .hero-backdrop{
      position:absolute;
      inset:0;
    }
    .hero-backdrop::after{
      content:"";
      position:absolute;
      inset:0;
      background:
        linear-gradient(90deg, rgba(13,27,42,.82) 0%, rgba(13,27,42,.56) 40%, rgba(13,27,42,.18) 100%),
        linear-gradient(180deg, rgba(15,95,215,.16), rgba(13,27,42,.34));
    }
    .eyebrow{
      letter-spacing:.18em;
      text-transform:uppercase;
      font-size:.78rem;
      font-weight:700;
      color:#667085;
    }
    .section-title{letter-spacing:-.03em}
    .primary-btn{
      display:inline-flex;
      align-items:center;
      justify-content:center;
      border-radius:9999px;
      background:var(--brand);
      color:white;
      font-weight:700;
      transition:all .2s ease;
      box-shadow:0 14px 28px rgba(15,95,215,.18);
    }
    .primary-btn:hover{background:var(--brand-dark);transform:translateY(-1px)}
    .secondary-btn{
      display:inline-flex;
      align-items:center;
      justify-content:center;
      border-radius:9999px;
      border:1px solid #c8d7f2;
      background:#fff;
      color:var(--brand);
      font-weight:700;
      transition:all .2s ease;
    }
    .secondary-btn:hover{background:var(--brand-soft)}
    .card,.quote-card,.resource-card,.highlight-card{
      background:var(--panel);
      border:1px solid var(--line);
      box-shadow:0 18px 40px rgba(16,24,40,.06);
    }
    .hero-image-wrap{
      overflow:hidden;
      border-radius:2rem;
      border:1px solid var(--line);
      box-shadow:0 28px 56px rgba(16,24,40,.12);
      position:relative;
    }
    .hero-image-wrap::after{
      content:"";
      position:absolute;
      inset:0;
      background:linear-gradient(180deg, rgba(16,24,40,.02), rgba(16,24,40,.12));
      pointer-events:none;
    }
    .metric{
      border:1px solid var(--line);
      background:rgba(255,255,255,.78);
      backdrop-filter: blur(8px);
    }
    .dark-band{
      background:
        radial-gradient(circle at top right, rgba(15,95,215,.18), transparent 28%),
        linear-gradient(180deg,#0d1b2a 0%, #10243d 100%);
    }
  </style>
</head>
<body>
  <header class="site-header fixed inset-x-0 top-0 z-50">
    <div class="container mx-auto px-4">
      <div class="flex items-center justify-between py-4">
        
<a href="#home" class="flex items-center gap-3">
  <svg width="220" height="56" viewBox="0 0 720 180" fill="none" xmlns="http://www.w3.org/2000/svg" aria-label="Inferiva logo" class="h-12 w-auto md:h-14">
    <defs>
      <linearGradient id="barGrad1" x1="16" y1="132" x2="70" y2="78" gradientUnits="userSpaceOnUse">
        <stop stop-color="#2EC5FF"/>
        <stop offset="1" stop-color="#0F8BFF"/>
      </linearGradient>
      <linearGradient id="barGrad2" x1="56" y1="132" x2="112" y2="56" gradientUnits="userSpaceOnUse">
        <stop stop-color="#1FAFFF"/>
        <stop offset="1" stop-color="#0C7BFF"/>
      </linearGradient>
      <linearGradient id="barGrad3" x1="96" y1="132" x2="154" y2="34" gradientUnits="userSpaceOnUse">
        <stop stop-color="#169BFF"/>
        <stop offset="1" stop-color="#FF9F1C"/>
      </linearGradient>
      <linearGradient id="sailGrad" x1="102" y1="148" x2="192" y2="56" gradientUnits="userSpaceOnUse">
        <stop stop-color="#0B4FB6"/>
        <stop offset="1" stop-color="#0A2B7A"/>
      </linearGradient>
    </defs>
    <g transform="translate(8,14)">
      <path d="M8 120L40 104V136H8V120Z" fill="url(#barGrad1)"/>
      <path d="M50 94L82 68V136H50V94Z" fill="url(#barGrad2)"/>
      <path d="M92 66L124 34V136H92V66Z" fill="url(#barGrad3)"/>
      <path d="M138 52L170 22V136H138V52Z" fill="#FF9F1C"/>
      <path d="M58 136L170 48V136H58Z" fill="url(#sailGrad)"/>
      <path d="M124 94L170 48V136H124V94Z" fill="#0A256B" opacity="0.85"/>
    </g>
    <g transform="translate(220,0)">
      <text x="0" y="96" font-family="Inter, Arial, Helvetica, sans-serif" font-size="78" font-weight="700" fill="#0C2E7A" letter-spacing="-2">Inferiva</text>
    </g>
  </svg>
</a>


        <nav class="hidden items-center gap-8 md:flex">
          <a href="#home" class="nav-link">Home</a>
          <a href="#solutions" class="nav-link">Solutions</a>
          <a href="#platform" class="nav-link">Platform</a>
          <a href="#consulting" class="nav-link">Consulting</a>
          <a href="#resources" class="nav-link">Resources</a>
          <a href="#contact" class="nav-link">Contact</a>
        </nav>

        <button id="mobile-menu-button" class="md:hidden rounded-xl border border-slate-200 px-3 py-2 text-slate-700" aria-label="Toggle menu">☰</button>
      </div>

      <nav id="mobile-menu" class="hidden border-t border-slate-200 pb-4 pt-3 md:hidden">
        <div class="flex flex-col gap-3">
          <a href="#home" class="nav-link">Home</a>
          <a href="#solutions" class="nav-link">Solutions</a>
          <a href="#platform" class="nav-link">Platform</a>
          <a href="#consulting" class="nav-link">Consulting</a>
          <a href="#resources" class="nav-link">Resources</a>
          <a href="#contact" class="nav-link">Contact</a>
        </div>
      </nav>
    </div>
  </header>

  <main>
    
<section id="home" class="hero-bg pt-24 md:pt-28">
  <div class="hero-backdrop">
    <img
      src="https://images.unsplash.com/photo-1521737604893-d14cc237f11d?auto=format&fit=crop&w=1800&q=80"
      alt="Professionals collaborating in a transformation workshop"
      class="h-full w-full object-cover"
    />
  </div>
  <div class="container relative z-10 mx-auto px-4 py-20 md:py-28">
    <div class="mx-auto max-w-3xl text-white text-center">
      <p class="eyebrow !text-slate-200">Transformation Intelligence</p>
      <h1 class="section-title mt-5 text-4xl font-bold leading-tight text-white md:text-6xl text-center mx-auto">
        Powering Transformations That Stick
      </h1>
      <p class="mt-6 max-w-2xl text-lg leading-8 text-slate-100 md:text-2xl">
        Smarter, Faster, Better – Your Partner for Real Change
      </p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a href="#contact" class="primary-btn px-8 py-3.5">Get Started</a>
        <a href="#platform" class="secondary-btn px-8 py-3.5 !border-white/50 !bg-white/10 !text-white hover:!bg-white/20">See Demo</a>
      </div>
    </div>
  </div>
</section>


    <section class="bg-white py-16">
      <div class="container mx-auto px-4">
        <div class="grid gap-5 md:grid-cols-4">
          <div class="highlight-card rounded-3xl px-6 py-6 text-center font-semibold text-slate-800">Insight-Driven Decisions</div>
          <div class="highlight-card rounded-3xl px-6 py-6 text-center font-semibold text-slate-800">Adaptive & Intelligent Platform</div>
          <div class="highlight-card rounded-3xl px-6 py-6 text-center font-semibold text-slate-800">Proven Adoption Framework</div>
          <div class="highlight-card rounded-3xl px-6 py-6 text-center font-semibold text-slate-800">Trusted by Industry Leaders</div>
        </div>
      </div>
    </section>

    <section id="solutions" class="bg-[var(--bg)] py-24">
      <div class="container mx-auto px-4">
        <div class="mx-auto max-w-3xl text-center">
          <p class="eyebrow">Core Offer</p>
          <h2 class="section-title mt-4 text-3xl font-bold text-slate-950 md:text-5xl">
            The platform and expertise to turn change into sustained progress
          </h2>
          <p class="mt-5 text-lg leading-8 text-slate-600">
            Inferiva blends productised insight with consulting depth, giving leadership teams both the intelligence and the execution support needed for successful transformation.
          </p>
        </div>

        <div class="mt-14 grid gap-8 lg:grid-cols-2">
          <article id="platform" class="card rounded-[2rem] p-8">
            <img
              src="https://images.unsplash.com/photo-1516321318423-f06f85e504b3?auto=format&fit=crop&w=1400&q=80"
              alt="Team reviewing platform dashboards"
              class="h-64 w-full rounded-3xl object-cover"
            />
            <h3 class="mt-7 text-2xl font-semibold text-slate-950">TransformIQ Platform</h3>
            <p class="mt-4 text-base leading-8 text-slate-600">
              An adaptive diagnostic engine delivering real-time, context-aware insight across readiness, risk, adoption and organisational momentum, so leaders can act with greater confidence.
            </p>
            <a href="#contact" class="mt-6 inline-block font-semibold text-[var(--brand)]">Learn More About TransformIQ →</a>
          </article>

          <article id="consulting" class="card rounded-[2rem] p-8">
            <img
              src="https://images.unsplash.com/photo-1520607162513-77705c0f0d4a?auto=format&fit=crop&w=1400&q=80"
              alt="Senior consultants facilitating transformation planning"
              class="h-64 w-full rounded-3xl object-cover"
            />
            <h3 class="mt-7 text-2xl font-semibold text-slate-950">Consulting Services</h3>
            <p class="mt-4 text-base leading-8 text-slate-600">
              Strategic advisory, workshops and executive coaching designed to unlock transformation potential, align stakeholders and create measurable momentum where it matters most.
            </p>
            <a href="#resources" class="mt-6 inline-block font-semibold text-[var(--brand)]"></a>
          </article>
        </div>
      </div>
    </section>

    <section class="dark-band py-24 text-white">
      <div class="container mx-auto px-4">
        <div class="grid items-start gap-8 lg:grid-cols-[.9fr_1.1fr]">
          <div>
            <p class="eyebrow !text-slate-300">Testimonials</p>
            <h2 class="section-title mt-4 text-3xl font-bold md:text-5xl">What leaders are saying</h2>
            <p class="mt-5 max-w-xl text-lg leading-8 text-slate-300">
              Inferiva is built to bring clarity, momentum and measurable confidence to transformation programmes.
            </p>
          </div>

          <div class="grid gap-6">
            <blockquote class="quote-card rounded-[2rem] bg-white/95 p-8 text-slate-900">
              <p class="text-xl italic leading-9">
                “Inferiva’s insights transformed how we approach change. The platform is a game-changer.”
              </p>
              <footer class="mt-5 text-sm font-semibold uppercase tracking-[0.16em] text-slate-500">CIO, Global Retail Firm</footer>
            </blockquote>
            <blockquote class="quote-card rounded-[2rem] bg-white/95 p-8 text-slate-900">
              <p class="text-xl italic leading-9">
                “The consulting team provided clarity and momentum when we needed it most.”
              </p>
              <footer class="mt-5 text-sm font-semibold uppercase tracking-[0.16em] text-slate-500">Transformation Lead, Tech Innovator</footer>
            </blockquote>
          </div>
        </div>
      </div>
    </section>

    <section id="resources" class="bg-white py-24">
      <div class="container mx-auto px-4">
        <div class="grid items-center gap-10 lg:grid-cols-[1.02fr_.98fr]">
          <div>
            <p class="eyebrow">Resources</p>
            <h2 class="section-title mt-4 text-3xl font-bold text-slate-950 md:text-5xl">
              Resources to fuel your transformation
            </h2>
            <p class="mt-5 max-w-2xl text-lg leading-8 text-slate-600">
              A sharper resource experience gives Inferiva credibility beyond the homepage. Use this section for blog articles, diagnostic guides, case studies and whitepapers.
            </p>
            <a href="#contact" class="primary-btn mt-8 px-8 py-3.5">Explore Our Blog & Whitepapers</a>
          </div>

          <div class="resource-card rounded-[2rem] p-8">
            <img
              src="https://images.unsplash.com/photo-1454165804606-c3d57bc86b40?auto=format&fit=crop&w=1400&q=80"
              alt="Executive reviewing reports and transformation data"
              class="h-64 w-full rounded-3xl object-cover"
            />
            <div class="mt-7">
              <div class="text-sm font-semibold uppercase tracking-[0.16em] text-slate-400">Featured</div>
              <h3 class="mt-3 text-2xl font-semibold text-slate-950">From transformation readiness to adoption momentum</h3>
              <p class="mt-4 leading-8 text-slate-600">
                Practical perspectives on identifying resistance, improving execution visibility and making change efforts far more likely to succeed.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section id="contact" class="bg-[var(--bg)] py-24">
      <div class="container mx-auto px-4">
        <div class="card rounded-[2rem] p-8 md:p-12">
          <div class="grid gap-10 lg:grid-cols-[1fr_.95fr]">
            <div>
              <p class="eyebrow">Contact</p>
              <h2 class="section-title mt-4 text-3xl font-bold text-slate-950 md:text-5xl">Start your next transformation with more clarity</h2>
              <p class="mt-5 max-w-2xl text-lg leading-8 text-slate-600">
                Whether you want a platform demonstration, strategic input or hands-on transformation support, Inferiva gives you a more structured path to action.
              </p>
            </div>

            <form class="space-y-5">
              <div>
                <label for="name" class="mb-2 block font-medium text-slate-700">Name</label>
                <input id="name" type="text" class="w-full rounded-2xl border border-slate-300 bg-white px-4 py-3 focus:border-slate-500 focus:outline-none" />
              </div>
              <div>
                <label for="email" class="mb-2 block font-medium text-slate-700">Email</label>
                <input id="email" type="email" class="w-full rounded-2xl border border-slate-300 bg-white px-4 py-3 focus:border-slate-500 focus:outline-none" />
              </div>
              <div>
                <label for="message" class="mb-2 block font-medium text-slate-700">Message</label>
                <textarea id="message" rows="6" class="w-full rounded-2xl border border-slate-300 bg-white px-4 py-3 focus:border-slate-500 focus:outline-none"></textarea>
              </div>
              <button type="submit" class="primary-btn px-8 py-3.5">Send Enquiry</button>
            </form>
          </div>
        </div>
      </div>
    </section>
  </main>

  <footer class="border-t border-slate-200 bg-white py-10">
    <div class="container mx-auto px-4">
      <div class="flex flex-col items-center justify-between gap-4 text-center md:flex-row md:text-left">
        <div class="text-slate-500">© <span id="current-year"></span> Inferiva. All rights reserved.</div>
        
      </div>
    </div>
  </footer>

  <script>
    document.getElementById('current-year').textContent = new Date().getFullYear();

    const mobileMenuButton = document.getElementById('mobile-menu-button');
    const mobileMenu = document.getElementById('mobile-menu');
    mobileMenuButton.addEventListener('click', () => mobileMenu.classList.toggle('hidden'));

    const navLinks = Array.from(document.querySelectorAll('.nav-link'));
    const sections = ['home','solutions','platform','consulting','resources','contact']
      .map(id => document.getElementById(id))
      .filter(Boolean);

    function setActiveLink(){
      const scrollY = window.scrollY + 140;
      let currentId = 'home';
      for(const section of sections){
        if(scrollY >= section.offsetTop) currentId = section.id;
      }
      navLinks.forEach(link => {
        link.classList.toggle('active', link.getAttribute('href') === `#${currentId}`);
      });
    }

    navLinks.forEach(link => {
      link.addEventListener('click', () => mobileMenu.classList.add('hidden'));
    });

    window.addEventListener('scroll', setActiveLink);
    window.addEventListener('load', setActiveLink);
  </script>
</body>
</html>
